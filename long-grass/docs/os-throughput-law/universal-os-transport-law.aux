\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces \textbf  {Empirical estimators and cross-architecture invariance.} (\textbf  {A})~Phase-coherence estimator: $R$ on the linear $y$-axis ($0$ to $1$) versus concentration parameter $K \in [0, 1]$ on the linear $x$-axis, $11$ values. Navy circles connected by a line trace the empirical $R$, which rises monotonically from $R \approx 0$ (uniform decision distribution) to $R \approx 1$ (fully concentrated), confirming that the estimator recovers the expected scaling. This is the empirical content of Definition~\ref {def:R-estimator} together with the monotonicity claim of Lemma~\ref {lem:R-monotone}. (\textbf  {B})~Lag estimator lower bound: minimum measured $\tau $ on the log $y$-axis versus the theoretical lower bound $1/f_\mathrm  {max}$ on the log $x$-axis, $30$ trials with $f_\mathrm  {max} \in [10^{3}, 10^{9}]$. Navy circles lie at or above the crimson dashed reference $\tau = 1/f_\mathrm  {max}$; zero violations across nearly seven decades. This is the empirical content of Theorem~\ref {thm:lag-bound}. (\textbf  {C})~Coupling estimator recovery: correlation between estimated and injected $g^{(ij)}$ on the linear $y$-axis versus decision-class count $N \in \{3, 4, 5\}$ on the linear $x$-axis, $20$ trials. Navy markers cluster at $\geq 0.95$; mean correlation $0.987$, maximum recovery error $0.042$. The crimson dashed reference at $0.5$ is the acceptance threshold. This is the empirical content of Algorithm~\ref {alg:coupling-est}. (\textbf  {D})~Cross-architecture invariance: predicted $TP^{-1}$ on the vertical axis as a 3D scatter, $x$-axis discrete over four architectures (microkernel, monolithic, exokernel, unikernel), $y$-axis is trial index $0$ to $4$, viewing angle elevation $20^{\circ }$ azimuth $-60^{\circ }$. Each architecture-trial pair receives one marker; the universal law produces consistent predictions under architecture-specific normalisations $\mathcal  {N}$. This is the empirical content of Theorem~\ref {thm:cross-arch}: the formula is architecture-agnostic up to the choice of $\mathcal  {N}$.}}{17}{figure.caption.8}\protected@file@percent }
\newlabel{fig:utl-panel-6}{{6}{17}{\textbf {Empirical estimators and cross-architecture invariance.} (\textbf {A})~Phase-coherence estimator: $R$ on the linear $y$-axis ($0$ to $1$) versus concentration parameter $K \in [0, 1]$ on the linear $x$-axis, $11$ values. Navy circles connected by a line trace the empirical $R$, which rises monotonically from $R \approx 0$ (uniform decision distribution) to $R \approx 1$ (fully concentrated), confirming that the estimator recovers the expected scaling. This is the empirical content of Definition~\ref {def:R-estimator} together with the monotonicity claim of Lemma~\ref {lem:R-monotone}. (\textbf {B})~Lag estimator lower bound: minimum measured $\tau $ on the log $y$-axis versus the theoretical lower bound $1/f_\mathrm {max}$ on the log $x$-axis, $30$ trials with $f_\mathrm {max} \in [10^{3}, 10^{9}]$. Navy circles lie at or above the crimson dashed reference $\tau = 1/f_\mathrm {max}$; zero violations across nearly seven decades. This is the empirical content of Theorem~\ref {thm:lag-bound}. (\textbf {C})~Coupling estimator recovery: correlation between estimated and injected $g^{(ij)}$ on the linear $y$-axis versus decision-class count $N \in \{3, 4, 5\}$ on the linear $x$-axis, $20$ trials. Navy markers cluster at $\geq 0.95$; mean correlation $0.987$, maximum recovery error $0.042$. The crimson dashed reference at $0.5$ is the acceptance threshold. This is the empirical content of Algorithm~\ref {alg:coupling-est}. (\textbf {D})~Cross-architecture invariance: predicted $TP^{-1}$ on the vertical axis as a 3D scatter, $x$-axis discrete over four architectures (microkernel, monolithic, exokernel, unikernel), $y$-axis is trial index $0$ to $4$, viewing angle elevation $20^{\circ }$ azimuth $-60^{\circ }$. Each architecture-trial pair receives one marker; the universal law produces consistent predictions under architecture-specific normalisations $\mathcal {N}$. This is the empirical content of Theorem~\ref {thm:cross-arch}: the formula is architecture-agnostic up to the choice of $\mathcal {N}$}{figure.caption.8}{}}
