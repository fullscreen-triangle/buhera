\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces \textbf  {Universal Transport Law: calibration against an independent Monte Carlo estimator.} (\textbf  {A})~Predicted versus measured $TP^{-1}$ on linear axes for $20$ randomly drawn synthetic kernels with $N \in \{2,3,4,5\}$ decision classes; entries of $\tau $ drawn uniformly from $[0.5, 5.0]$ and entries of $g$ symmetrised from $[0.1, 1.0]$. Steelblue circles are the Monte Carlo estimator at $n_\mathrm  {dec}=2 \times 10^{4}$ uniform samples; the crimson dashed line is $y=x$. The estimator recovers $TP^{-1}=N^{-2}\DOTSB \sum@ \slimits@ _{i,j}\tau ^{(ij)} g^{(ij)}$ with maximum relative error $7.12 \times 10^{-3}$ and mean relative error $2.64 \times 10^{-3}$. This is the empirical content of Theorem~\ref {thm:utl} (Universal Transport Law). (\textbf  {B})~Per-trial residual: relative error $|TP^{-1}_\mathrm  {predicted} - TP^{-1}_\mathrm  {measured}| / TP^{-1}_\mathrm  {predicted}$ on the linear $y$-axis versus trial index $1$ to $20$ on the linear $x$-axis. The $0.10$ tolerance threshold (crimson dashed reference) is more than an order of magnitude above every measured residual; zero violations. (\textbf  {C})~Histogram of relative errors across all $20$ trials in $12$ equal-width bins (lightblue bars, navy edges); the rightmost bin contains the maximum value $7.12 \times 10^{-3}$, far below the acceptance tolerance. (\textbf  {D})~Three-dimensional surface of the integrand $\tau \cdot g$ over $\tau \in [0.5, 5.0]$, $g \in [0.1, 1.0]$, blues colourmap, viewing angle elevation $22^{\circ }$ azimuth $-58^{\circ }$. The volume under this surface, divided by $N^{2}$, is the universal-law prediction; the Monte Carlo estimator in panel~A independently estimates the same quantity.}}{7}{figure.caption.3}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{fig:utl-panel-1}{{1}{7}{\textbf {Universal Transport Law: calibration against an independent Monte Carlo estimator.} (\textbf {A})~Predicted versus measured $TP^{-1}$ on linear axes for $20$ randomly drawn synthetic kernels with $N \in \{2,3,4,5\}$ decision classes; entries of $\tau $ drawn uniformly from $[0.5, 5.0]$ and entries of $g$ symmetrised from $[0.1, 1.0]$. Steelblue circles are the Monte Carlo estimator at $n_\mathrm {dec}=2 \times 10^{4}$ uniform samples; the crimson dashed line is $y=x$. The estimator recovers $TP^{-1}=N^{-2}\sum _{i,j}\tau ^{(ij)} g^{(ij)}$ with maximum relative error $7.12 \times 10^{-3}$ and mean relative error $2.64 \times 10^{-3}$. This is the empirical content of Theorem~\ref {thm:utl} (Universal Transport Law). (\textbf {B})~Per-trial residual: relative error $|TP^{-1}_\mathrm {predicted} - TP^{-1}_\mathrm {measured}| / TP^{-1}_\mathrm {predicted}$ on the linear $y$-axis versus trial index $1$ to $20$ on the linear $x$-axis. The $0.10$ tolerance threshold (crimson dashed reference) is more than an order of magnitude above every measured residual; zero violations. (\textbf {C})~Histogram of relative errors across all $20$ trials in $12$ equal-width bins (lightblue bars, navy edges); the rightmost bin contains the maximum value $7.12 \times 10^{-3}$, far below the acceptance tolerance. (\textbf {D})~Three-dimensional surface of the integrand $\tau \cdot g$ over $\tau \in [0.5, 5.0]$, $g \in [0.1, 1.0]$, blues colourmap, viewing angle elevation $22^{\circ }$ azimuth $-58^{\circ }$. The volume under this surface, divided by $N^{2}$, is the universal-law prediction; the Monte Carlo estimator in panel~A independently estimates the same quantity}{figure.caption.3}{}}
