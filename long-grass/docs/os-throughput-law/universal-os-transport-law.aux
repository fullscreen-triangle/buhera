\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces \textbf  {Critical slowing as a load indicator.} (\textbf  {A})~Relaxation time $\tau _\mathrm  {relax}$ on the log $y$-axis versus distance $|R - R_b|$ from the nearest regime boundary $R_b$ on the log $x$-axis, $24$ measurements spanning $|R-R_b| \in [10^{-3}, 1]$. Navy circles are simulated $\tau _\mathrm  {relax}$, amber crosses are the predicted $\propto |R-R_b|^{-1}$, and the crimson dashed reference traces the closed-form scaling. Both follow the law over three decades. This is the empirical content of Theorem~\ref {thm:critical-slowing}: $\tau _\mathrm  {relax}$ diverges as the operating point approaches a regime boundary, with exponent $-1$. (\textbf  {B})~Load indicator: estimated distance-to-boundary $\hat  d$ on the linear $y$-axis versus true distance $d$ on the linear $x$-axis, $50$ trials. Navy markers (correct classification, $50/50$ trials) lie exactly on the crimson identity line; the indicator achieves $100\%$ classification accuracy, the empirical content of Algorithm~\ref {alg:load} together with Theorem~\ref {thm:critical-slowing}. (\textbf  {C})~Per-trial relative error $|\hat  d - d|/d$ on the linear $y$-axis versus trial index $1$ to $50$ on the linear $x$-axis. The mean residual is shown in the title; all trials lie within numerical tolerance. (\textbf  {D})~Three-dimensional surface of $\log _{10}(\tau _\mathrm  {relax})$ over $R \in [0.1, 0.95]$, perturbation $\epsilon \in [0.01, 0.3]$, blues colourmap, viewing angle elevation $22^{\circ }$ azimuth $-50^{\circ }$. The structural divergence near regime boundaries is what the load indicator exploits.}}{13}{figure.caption.6}\protected@file@percent }
\newlabel{fig:utl-panel-4}{{4}{13}{\textbf {Critical slowing as a load indicator.} (\textbf {A})~Relaxation time $\tau _\mathrm {relax}$ on the log $y$-axis versus distance $|R - R_b|$ from the nearest regime boundary $R_b$ on the log $x$-axis, $24$ measurements spanning $|R-R_b| \in [10^{-3}, 1]$. Navy circles are simulated $\tau _\mathrm {relax}$, amber crosses are the predicted $\propto |R-R_b|^{-1}$, and the crimson dashed reference traces the closed-form scaling. Both follow the law over three decades. This is the empirical content of Theorem~\ref {thm:critical-slowing}: $\tau _\mathrm {relax}$ diverges as the operating point approaches a regime boundary, with exponent $-1$. (\textbf {B})~Load indicator: estimated distance-to-boundary $\hat d$ on the linear $y$-axis versus true distance $d$ on the linear $x$-axis, $50$ trials. Navy markers (correct classification, $50/50$ trials) lie exactly on the crimson identity line; the indicator achieves $100\%$ classification accuracy, the empirical content of Algorithm~\ref {alg:load} together with Theorem~\ref {thm:critical-slowing}. (\textbf {C})~Per-trial relative error $|\hat d - d|/d$ on the linear $y$-axis versus trial index $1$ to $50$ on the linear $x$-axis. The mean residual is shown in the title; all trials lie within numerical tolerance. (\textbf {D})~Three-dimensional surface of $\log _{10}(\tau _\mathrm {relax})$ over $R \in [0.1, 0.95]$, perturbation $\epsilon \in [0.01, 0.3]$, blues colourmap, viewing angle elevation $22^{\circ }$ azimuth $-50^{\circ }$. The structural divergence near regime boundaries is what the load indicator exploits}{figure.caption.6}{}}
