{
  "name": "@buhera/purpose",
  "version": "0.1.0",
  "description": "Carry the uncertainty, not the knowledge: a graph-and-residue library for the tandem carry of a finite reasoning agent's context. No LLM, no tokenizer, no content store.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "context",
    "residue",
    "minimum-cut",
    "knapsack",
    "reachability",
    "necessity",
    "finite-agent"
  ],
  "author": "Kundai Farai Sachikonye",
  "license": "MIT",
  "private": true,
  "sideEffects": false
}
